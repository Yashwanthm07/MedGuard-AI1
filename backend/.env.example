PORT=8000
DEBUG=false
MONGODB_URI=mongodb://localhost:27017/medguard

# Free local OCR mode (no paid provider keys required)
# Keep these commented unless you intentionally re-enable external providers.
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# API Ninjas OCR fallback (free tier: 200KB per image)
API_NINJAS_API_KEY=

# OCR.space fallback disabled in current pipeline (kept only for manual rollback)
OCR_SPACE_API_KEY=

# Local OCR tuning
LOCAL_MULTI_OCR_ENABLED=true

